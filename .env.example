# plurali — environment

# Neon (serverless Postgres) connection string. Get one at https://neon.tech
# (or provision via Vercel's Marketplace → Neon). Needed for migrations + runtime.
# Copy this file to .env.local and fill in your URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# APP_ORIGIN=https://your-domain  # optional; origin for the server-side GraphQL self-fetch (?gql=1)
